{
  "redirects": [
    {
      "source": "/pair",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "functions": {
    "api/proxy.js": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}
